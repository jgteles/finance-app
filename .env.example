# ======================================================
# 🐘 DATABASE - PostgreSQL
# ======================================================

POSTGRES_DB=financial_dashboard
POSTGRES_USER=db
POSTGRES_PASSWORD=change_this_password
POSTGRES_HOST=db
POSTGRES_PORT=5432


# ======================================================
# 🐍 DJANGO SETTINGS
# ======================================================

DEBUG=True
ENVIRONMENT=development
SECRET_KEY=change_this_secret_key_in_production

ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ======================================================
# 💰 CDI (rendimento diário)
# ======================================================
# Percentual diário do CDI usado no cálculo (ex.: 0.05 = 0.05% ao dia)
CDI_DAILY_RATE_PERCENT=0


# ======================================================
# 🐳 PGADMIN
# ======================================================

PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=change_this_password


# ======================================================
# ⚛️ FRONTEND - VITE
# ======================================================

VITE_API_URL=http://localhost:8000/api
VITE_API_TIMEOUT=30000
VITE_ENVIRONMENT=development

# ⚠️ Nunca colocar chave real aqui
VITE_GOOGLE_AI_KEY=your_google_ai_key_here


# ======================================================
# 🚀 PRODUÇÃO (exemplo)
# ======================================================
# DEBUG=False
# ENVIRONMENT=production
# ALLOWED_HOSTS=yourdomain.com
# CORS_ALLOWED_ORIGINS=https://yourdomain.com
